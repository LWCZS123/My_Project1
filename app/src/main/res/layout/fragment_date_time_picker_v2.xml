<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_rounded1"
    android:layout_gravity="center"
    android:paddingBottom="8dp">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/llHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="8dp"
        android:gravity="bottom"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">
        <TextView
            android:id="@+id/tvMonthBig"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#000000" />
        <TextView
            android:id="@+id/tvYearSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#999999"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="4dp"/>
    </LinearLayout>

    <!--
        使用 CalendarLayout 解决动态高度同步问题
        app:calendar_show_mode="only_month_view" 配合代码禁用折叠
    -->
    <LinearLayout
        android:id="@+id/llCalendarContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.haibin.calendarview.CalendarView
            android:id="@+id/calendarView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:month_view="com.example.my_project1.ui.view.calendar.PickerMonthView"
            app:month_view_show_mode="mode_only_current"
            app:calendar_show_mode="only_month_view"
            app:week_bar_view="com.haibin.calendarview.WeekBar"
            app:week_bar_height="32dp"
            app:calendar_padding="10dp"
            app:week_text_size="12sp"
            app:week_start_with="sun"
            app:current_month_text_color="#333333"
            app:selected_theme_color="@color/calendar_selection"
            app:selected_text_color="#FFFFFF"
            app:day_text_size="16sp"
            app:lunar_text_size="9sp" />

        <LinearLayout
            android:id="@+id/llBottomContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Set Time Section -->
            <LinearLayout
                android:id="@+id/llSetTimeHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:minHeight="48dp"
                android:paddingHorizontal="20dp"
                android:paddingVertical="12dp">
                <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_clock" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:text="设置时间"
                    android:textColor="#000000"
                    android:textSize="15sp" />
                <ImageView android:id="@+id/ivTimeArrow" android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_arrow_right1" />
            </LinearLayout>

            <!-- Time Picker -->
            <LinearLayout
                android:id="@+id/llTimePickerContainer"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:visibility="gone"
                android:paddingHorizontal="40dp">
                <com.contrarywind.view.WheelView android:id="@+id/wheelHour" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=":" android:textSize="22sp" android:textStyle="bold" android:layout_marginHorizontal="16dp"/>
                <com.contrarywind.view.WheelView android:id="@+id/wheelMinute" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"/>
            </LinearLayout>

            <!-- Buttons -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="8dp">
                <TextView android:id="@+id/tvCancel" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="取消" android:gravity="center" android:textSize="16sp" android:textColor="#999999" android:clickable="true" android:background="?attr/selectableItemBackground"/>
                <TextView android:id="@+id/tvConfirm" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="确定" android:gravity="center" android:textSize="16sp" android:textColor="@color/calendar_selection" android:textStyle="bold" android:clickable="true" android:background="?attr/selectableItemBackground"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>