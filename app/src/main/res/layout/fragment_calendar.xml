<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fitsSystemWindows="true"
    tools:context=".ui.fragment.CalendarFragment">

    <!-- 顶部标题栏 -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/white"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tv_year_month"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="2026 / 7"
            android:textColor="#333333"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_relative_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="今天"
            android:textColor="#999999"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="@id/tv_year_month"
            app:layout_constraintStart_toEndOf="@id/tv_year_month"
            app:layout_constraintTop_toTopOf="@id/tv_year_month" />

        <ImageView
            android:id="@+id/iv_add_bill"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="16dp"
            android:padding="8dp"
            android:src="@drawable/ic_add"
            app:tint="@color/black"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/iv_more"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/iv_more"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:padding="8dp"
            android:src="@drawable/ic_more_vert"
            app:tint="@color/black"

            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 日历布局 -->
    <com.haibin.calendarview.CalendarLayout
        android:id="@+id/calendarLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:background="#F2F4F8"
        app:calendar_content_view_id="@+id/rv_bills"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <com.haibin.calendarview.CalendarView
            android:id="@+id/calendarView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_calendar_bottom_rounded"
            android:paddingBottom="16dp"
            app:calendar_padding="10dp"
            app:month_view="com.example.my_project1.ui.view.calendar.CustomMonthView"
            app:week_view="com.example.my_project1.ui.view.calendar.CustomWeekView"
            app:current_month_text_color="#333333"
            app:selected_theme_color="#3F8BFF"
            app:selected_text_color="#FFFFFF"
            app:day_text_size="18sp"
            app:lunar_text_size="10sp"
            app:month_view_show_mode="mode_fix"
            app:month_view_auto_select_day="last_select_day"
            app:week_bar_height="32dp">

            <!-- 底部指示拉杆 (作为 CalendarView 的子 View) -->
            <View
                android:layout_width="32dp"
                android:layout_height="4dp"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="2dp"
                android:background="@drawable/bg_calendar_handle" />
        </com.haibin.calendarview.CalendarView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_bills"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#F2F4F8"
            android:clipToPadding="false"
            android:paddingHorizontal="6dp"
            android:paddingTop="6dp"
            android:paddingBottom="200dp"
            tools:listitem="@layout/item_transaction" />

    </com.haibin.calendarview.CalendarLayout>

    <!-- 回到今天按钮 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_today"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="100dp"
        android:padding="0dp"
        android:text="今"
        android:textColor="@color/white"
        android:textSize="18sp"
        app:backgroundTint="#3F8BFF"
        app:cornerRadius="28dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
