<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet1"
    android:orientation="vertical"
    android:padding="8dp">

    <TextView
        android:id="@+id/tv_edit_account"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="?attr/selectableItemBackground"
        android:gravity="center"
        android:text="修改账户"
        android:textColor="#2196F3"
        android:textSize="16sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#EEEEEE" />

    <TextView
        android:id="@+id/tv_hide_account"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="?attr/selectableItemBackground"
        android:gravity="center"
        android:text="隐藏账户"
        android:textColor="#2196F3"
        android:textSize="16sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#EEEEEE" />

    <TextView
        android:id="@+id/tv_archive_account"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="?attr/selectableItemBackground"
        android:gravity="center"
        android:text="归档账户"
        android:textColor="#2196F3"
        android:textSize="16sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#EEEEEE" />

    <TextView
        android:id="@+id/tv_account_info"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="?attr/selectableItemBackground"
        android:gravity="center"
        android:text="账户信息"
        android:textColor="#2196F3"
        android:textSize="16sp" />

    <View
        android:id="@+id/tv_divider_installment_1"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#EEEEEE" />

    <TextView
        android:id="@+id/tv_consumer_installment"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="?attr/selectableItemBackground"
        android:gravity="center"
        android:text="消费分期"
        android:textColor="#2196F3"
        android:textSize="16sp" />

    <View
        android:id="@+id/tv_divider_installment_2"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#EEEEEE" />

    <TextView
        android:id="@+id/tv_bill_installment"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="?attr/selectableItemBackground"
        android:gravity="center"
        android:text="账单分期"
        android:textColor="#2196F3"
        android:textSize="16sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#EEEEEE" />

    <TextView
        android:id="@+id/tv_delete_account"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="?attr/selectableItemBackground"
        android:gravity="center"
        android:text="删除账户"
        android:textColor="#F44336"
        android:textSize="16sp" />

    <View
        android:id="@+id/divider_cancel"
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:background="#F5F5F5" />

    <TextView
        android:id="@+id/tv_cancel"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="?attr/selectableItemBackground"
        android:gravity="center"
        android:text="取消"
        android:textColor="#2196F3"
        android:textSize="16sp" />

</LinearLayout>
