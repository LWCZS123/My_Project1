<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F7"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- Top Bar -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:text="手机"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#1C1C1E" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:padding="8dp"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/btn_edit"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_edit1"
                    android:scaleType="centerInside"
                    app:tint="#8E8E93"
                     />
                <View
                    android:layout_width="24dp"
                    android:layout_height="24dp"/>


                <ImageView
                    android:id="@+id/btn_delete"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_trash"
                    android:scaleType="centerInside"
                    app:tint="#8E8E93"
                    />
            </LinearLayout>
        </RelativeLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingTop="20dp"
            android:paddingBottom="8dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="240dp"
                android:layout_height="240dp"
                app:cardCornerRadius="120dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeWidth="0dp"
                app:cardUseCompatPadding="true"
                app:cardPreventCornerOverlap="false">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <!-- 圆形进度条（DonutProgress） -->
                    <com.github.lzyzsd.circleprogress.DonutProgress
                        android:id="@+id/donut_progress"
                        android:layout_width="200dp"
                        android:layout_height="200dp"
                        android:layout_gravity="center"
                        app:donut_progress="16"
                        app:donut_finished_color="#1C1C1E"
                        app:donut_unfinished_color="#E5E5EA"
                        app:donut_finished_stroke_width="14dp"
                        app:donut_unfinished_stroke_width="14dp"
                        app:donut_show_text="false" />

                    <!-- 中心文字 -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tv_saved_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="已存"
                            android:textSize="13sp"
                            android:textColor="#8E8E93" />

                        <TextView
                            android:id="@+id/tv_percent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="16%"
                            android:textSize="36sp"
                            android:textStyle="bold"
                            android:textColor="#1C1C1E"
                            android:layout_marginTop="2dp" />

                        <TextView
                            android:id="@+id/tv_amount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$ 310"
                            android:textSize="14sp"
                            android:textColor="#1C1C1E"
                            android:background="@drawable/bg_pill_gray"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:paddingTop="6dp"
                            android:paddingBottom="6dp"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>

                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Add Record Button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="16dp"
            android:paddingBottom="4dp">
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fab_add"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_add"
                app:backgroundTint="#FFFFFF"
                app:tint="#1C1C1E"
                app:fabSize="normal"
                app:elevation="4dp"
                android:contentDescription="添加记录" />


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="添加记录"
                android:textSize="13sp"
                android:textColor="#8E8E93"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- Stats Grid (2x2) -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="2"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:useDefaultMargins="false">

            <!-- Card 1: Target Amount -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_target"
                        android:background="@drawable/bg_icon_orange"
                        android:padding="8dp"
                        android:contentDescription="目标" />

                    <TextView
                        android:id="@+id/tv_goal_amount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$ 2,000"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#1C1C1E"
                        android:layout_marginTop="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="目标金额"
                        android:textSize="13sp"
                        android:textColor="#8E8E93"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card 2: Remaining Amount -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_piggy_bank"
                        android:background="@drawable/bg_icon_blue"
                        android:padding="8dp"
                        android:contentDescription="剩余" />

                    <TextView
                        android:id="@+id/tv_remaining"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$ 1,690"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#1C1C1E"
                        android:layout_marginTop="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="剩余金额"
                        android:textSize="13sp"
                        android:textColor="#8E8E93"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card 3: Start Date -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_save_calendar"
                        android:background="@drawable/bg_icon_purple"
                        android:padding="8dp"
                        android:contentDescription="日期" />

                    <TextView
                        android:id="@+id/tv_start_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2026.02.17"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#1C1C1E"
                        android:layout_marginTop="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="开始日期"
                        android:textSize="13sp"
                        android:textColor="#8E8E93"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card 4: Days Elapsed -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_clock1"
                        android:background="@drawable/bg_icon_teal"
                        android:padding="8dp"
                        android:contentDescription="已过天数" />

                    <TextView
                        android:id="@+id/tv_days_elapsed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="55"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#1C1C1E"
                        android:layout_marginTop="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="已过天数"
                        android:textSize="13sp"
                        android:textColor="#8E8E93"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </GridLayout>

        <!-- =========================================
             历史记录区域
             ========================================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="历史记录"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#1C1C1E"
                android:paddingBottom="12dp" />

            <!--
                RecyclerView 注意事项：
                1. nestedScrollingEnabled="false" ← 必须设置！
                   否则 RecyclerView 会自己拦截滚动，导致外层 ScrollView 无法滚动
                2. 高度用 wrap_content，配合外层 ScrollView 整体滚动
                3. overScrollMode="never" 去掉边缘过渡动画，避免与 ScrollView 冲突
                4. 在代码中绑定：
                   rv_history.layoutManager = LinearLayoutManager(context)
                   rv_history.adapter = HistoryAdapter(list)
                   // 不需要额外设置 hasFixedSize(true)，因为数据量可变
            -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_history"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>