<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#D5F3FE"

    >

    <!-- 顶部栏 -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#D5F3FE"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="16dp"
            android:src="@drawable/ic_back3"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="账单统计"
            android:textColor="#2F5FFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <View
            android:layout_width="40dp"
            android:layout_height="1dp"/>
    </LinearLayout>

    <!-- 主滚动区域 -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="56dp"
        android:scrollbars="none"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_gradient"
            android:padding="16dp">

            <!-- 周/月/年/自定义切换 -->
            <LinearLayout
                android:id="@+id/ll_period_tabs"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:background="@drawable/bg_capsule"
                android:padding="4dp">

                <TextView
                    android:id="@+id/tab_week"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="周"
                    android:textColor="#333"/>

                <TextView
                    android:id="@+id/tab_month"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_tab_selected1"
                    android:gravity="center"
                    android:text="月"
                    android:textColor="#333"/>

                <TextView
                    android:id="@+id/tab_year"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="年"/>

                <TextView
                    android:id="@+id/tab_custom"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="自定义"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_custom_date_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="10dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_custom_start"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="开始日期"
                    android:textColor="#2F5FFF"
                    android:textSize="14sp"
                    android:clickable="false"
                    android:focusable="false"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" — "
                    android:textColor="#888"
                    android:textSize="16sp"
                    android:layout_marginHorizontal="8dp"/>

                <TextView
                    android:id="@+id/tv_custom_end"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="结束日期"
                    android:textColor="#2F5FFF"
                    android:textSize="14sp"
                    android:clickable="false"
                    android:focusable="false"/>
            </LinearLayout>

            <!-- 日期导航 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/iv_left"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_arrow_left"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_start_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2026.3.1"
                        android:gravity="end|center_vertical"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" - "
                        android:textSize="16sp"
                        android:layout_marginHorizontal="6dp"/>

                    <TextView
                        android:id="@+id/tv_end_date"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:text="3.31"
                        android:gravity="end|center_vertical"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/iv_right"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_arrow_right"/>
            </LinearLayout>

            <!-- 汇总卡片（票据风格） -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:paddingTop="18dp"
                        android:paddingBottom="18dp">

                        <!-- 支出 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="支出"
                                android:textColor="#666"
                                android:textSize="14sp"
                                android:layout_marginBottom="4dp"/>
                            <TextView
                                android:id="@+id/tv_total_expense"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="¥0.00"
                                android:textColor="#FF4C5B"
                                android:textSize="20sp"
                                android:textStyle="bold"/>
                        </LinearLayout>

                        <!-- 分割线 -->
                        <View
                            android:layout_width="1dp"
                            android:layout_height="40dp"
                            android:background="#E0E0E0"/>

                        <!-- 收入 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="收入"
                                android:textColor="#666"
                                android:textSize="14sp"
                                android:layout_marginBottom="4dp"/>
                            <TextView
                                android:id="@+id/tv_total_income"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="¥0.00"
                                android:textColor="#4CAF50"
                                android:textSize="20sp"
                                android:textStyle="bold"/>
                        </LinearLayout>

                        <!-- 分割线 -->
                        <View
                            android:layout_width="1dp"
                            android:layout_height="40dp"
                            android:background="#E0E0E0"/>

                        <!-- 结余 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="结余"
                                android:textColor="#666"
                                android:textSize="14sp"
                                android:layout_marginBottom="4dp"/>
                            <TextView
                                android:id="@+id/tv_total_balance"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="¥0.00"
                                android:textColor="#2F5FFF"
                                android:textSize="20sp"
                                android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- 虚线分割 + 缺口 -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="16dp">
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="2dp"
                            android:layout_gravity="center_vertical"
                            android:layout_marginStart="16dp"
                            android:layout_marginEnd="16dp"
                            android:background="@drawable/bg_coupon_dash"/>
                        <View
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_gravity="start|center_vertical"
                            android:background="@drawable/bg_notch1"
                            android:translationX="-8dp"/>
                        <View
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_gravity="end|center_vertical"
                            android:background="@drawable/bg_notch1"
                            android:translationX="8dp"/>
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="8dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="16dp">
                        <ImageView
                            android:id="@+id/iv_tip_icon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_healthy_food"
                            android:contentDescription="tip"/>
                        <TextView
                            android:id="@+id/tv_tip_text"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:text="今天消费了啥？"
                            android:textColor="#666666"
                            android:textSize="14sp"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingEnd="16dp"
                        android:paddingStart="16dp"
                        android:paddingBottom="16dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:background="@drawable/bg_gray_rounded"
                            android:padding="16dp"
                            >
                            <!-- 内部文字 -->
                            <TextView
                                android:id="@+id/tv_gray_text"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="货比三家肯定不吃亏，多看看价格再决定，说不定还能发现惊喜优惠。"
                                android:textColor="#4D4D4D"
                                android:textSize="14sp"
                                android:gravity="start"
                                android:lineSpacingExtra="2dp" />
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="12dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_gravity="bottom"
                        android:clipChildren="false"
                        android:layout_marginTop="0dp">

                        <!-- 半缺口，每个 8dp，间隔 4dp -->
                        <View
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:translationY="6dp"
                            android:layout_marginEnd="32dp"
                            android:layout_marginStart="12dp"
                            android:background="@drawable/bg_notch1"/>
                        <View
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:translationY="6dp"
                            android:layout_marginEnd="32dp"
                            android:background="@drawable/bg_notch1"/>

                        <View
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:translationY="6dp"
                            android:layout_marginEnd="32dp"
                            android:background="@drawable/bg_notch1"/>
                        <View
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:translationY="6dp"
                            android:layout_marginEnd="32dp"
                            android:background="@drawable/bg_notch1"/>

                        <View
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:translationY="6dp"
                            android:layout_marginEnd="32dp"
                            android:background="@drawable/bg_notch1"/>
                        <View
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:translationY="6dp"
                            android:layout_marginEnd="32dp"
                            android:background="@drawable/bg_notch1"/>

                        <View
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:translationY="6dp"
                            android:layout_marginEnd="32dp"
                            android:background="@drawable/bg_notch1"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== 柱状图卡片 ===== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- 标题行 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="收支柱状图"
                            android:textColor="#1A1A1A"
                            android:textSize="16sp"
                            android:textStyle="bold"/>

                        <!-- 图例 -->
                        <View
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="@drawable/bg_legend_circle_red"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="支出"
                            android:textSize="12sp"
                            android:textColor="#666"
                            android:layout_marginStart="4dp"
                            android:layout_marginEnd="8dp"/>

                        <View
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="@drawable/bg_legend_circle_green"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="收入"
                            android:textSize="12sp"
                            android:textColor="#666"
                            android:layout_marginStart="4dp"
                            android:layout_marginEnd="8dp"/>

                        <View
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="@drawable/bg_legend_circle_blue"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="结余"
                            android:textSize="12sp"
                            android:textColor="#666"
                            android:layout_marginStart="4dp"/>
                    </LinearLayout>

                    <!-- 柱状图（修复：居中 + Y轴永不消失）-->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="220dp"
                        android:gravity="center">

                        <HorizontalScrollView
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:scrollbars="none"
                            android:overScrollMode="never">

                            <com.example.my_project1.ui.view.BarChartView
                                android:id="@+id/bar_chart"
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:minWidth="300dp"/>
                        </HorizontalScrollView>

                        <!-- 占位图（已居中+放大） -->
                        <LinearLayout
                            android:id="@+id/bar_chart_empty"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <ImageView
                                android:layout_width="120dp"
                                android:layout_height="120dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_no_data1"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="暂无数据"
                                android:textColor="#888888"
                                android:textSize="14sp"
                                android:layout_marginTop="8dp"/>
                        </LinearLayout>
                    </FrameLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== 曲线图卡片 ===== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- 标题行 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="收支趋势"
                            android:textColor="#1A1A1A"
                            android:textSize="16sp"
                            android:textStyle="bold"/>

                        <View
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="@drawable/bg_legend_circle_red"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="支出"
                            android:textSize="12sp"
                            android:textColor="#666"
                            android:layout_marginStart="4dp"
                            android:layout_marginEnd="8dp"/>

                        <View
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="@drawable/bg_legend_circle_green"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="收入"
                            android:textSize="12sp"
                            android:textColor="#666"
                            android:layout_marginStart="4dp"
                            android:layout_marginEnd="8dp"/>

                        <View
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="@drawable/bg_legend_circle_blue"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="结余"
                            android:textSize="12sp"
                            android:textColor="#666"
                            android:layout_marginStart="4dp"/>
                    </LinearLayout>

                    <!-- 曲线图（修复：居中 + Y轴永不消失） -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="220dp"
                        android:gravity="center">

                        <HorizontalScrollView
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:scrollbars="none"
                            android:overScrollMode="never">

                            <com.example.my_project1.ui.view.LineChartView
                                android:id="@+id/line_chart"
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:minWidth="300dp"/>
                        </HorizontalScrollView>

                        <!-- 占位图（已居中+放大） -->
                        <LinearLayout
                            android:id="@+id/line_chart_empty"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <ImageView
                                android:layout_width="120dp"
                                android:layout_height="120dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_no_data1"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="暂无数据"
                                android:textColor="#888888"
                                android:textSize="14sp"
                                android:layout_marginTop="8dp"/>
                        </LinearLayout>
                    </FrameLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== 饼图卡片 ===== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- 标题 + 支出/收入切换 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="支出分类构成"
                            android:textColor="#1A1A1A"
                            android:textSize="16sp"
                            android:textStyle="bold"/>

                        <!-- 支出/收入胶囊切换 -->
                        <LinearLayout
                            android:id="@+id/ll_pie_type_tabs"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:orientation="horizontal"
                            android:background="@drawable/bg_capsule_small"
                            android:padding="3dp">

                            <TextView
                                android:id="@+id/tab_pie_expense"
                                android:layout_width="56dp"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="支出"
                                android:textSize="13sp"
                                android:background="@drawable/bg_tab_selected_blue"
                                android:textColor="#FFFFFF"/>

                            <TextView
                                android:id="@+id/tab_pie_income"
                                android:layout_width="56dp"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="收入"
                                android:textSize="13sp"
                                android:textColor="#888"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- 饼图 + 中心文字 -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="260dp"
                        android:layout_gravity="center_horizontal">

                        <com.example.my_project1.ui.view.PieChartView
                            android:id="@+id/pie_chart"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"/>

                        <!-- 中心信息 -->
                        <LinearLayout
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:layout_gravity="center"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/tv_pie_center_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="本月支出"
                                android:textColor="#888"
                                android:textSize="12sp"/>

                            <TextView
                                android:id="@+id/tv_pie_center_amount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="¥0.00"
                                android:textColor="#1A1A1A"
                                android:textSize="16sp"
                                android:textStyle="bold"/>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/pie_chart_empty"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <ImageView
                                android:layout_width="120dp"
                                android:layout_height="120dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_no_data1"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="暂无数据"
                                android:textColor="#888888"
                                android:textSize="14sp"
                                android:layout_marginTop="8dp"/>
                        </LinearLayout>
                    </FrameLayout>

                    <!-- 分类列表 -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_category_list"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:nestedScrollingEnabled="false"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>