<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="6dp"
    android:layout_marginVertical="6dp"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#FFFFFF"
    app:rippleColor="#304FFE">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 主分类行 -->
        <LinearLayout
            android:id="@+id/layoutCategoryMain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:background="#00000000"
            android:minHeight="72dp">

            <!-- 折叠箭头 -->
            <ImageView
                android:id="@+id/imageViewExpandArrow"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:padding="4dp"
                android:layout_marginEnd="5dp"
                android:contentDescription="@string/expand_arrow_description"
                android:src="@drawable/right"/>

            <!-- 分类图标 -->
            <ImageView
                android:id="@+id/imageViewCategoryIcon"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/category_icon_background"
                android:contentDescription="@string/category_icon_description"
                android:padding="8dp"
                android:scaleType="centerInside"
                tools:src="@drawable/ic_food" />

            <!-- 分类名 -->
            <TextView
                android:id="@+id/textViewCategoryName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textSize="20sp"
                android:textStyle="bold"
                tools:text="餐饮" />

            <!-- 更多按钮 -->
            <ImageView
                android:id="@+id/imageViewMoreOptions"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:padding="4dp"
                android:layout_marginStart="4dp"
                android:contentDescription="@string/content_description_more"
                android:src="@drawable/ic_more_vert"
                app:tint="#666666"
                />

        </LinearLayout>

        <!-- 折叠内容（子分类容器） -->
        <LinearLayout
            android:id="@+id/layoutSubCategoriesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="16dp"
                android:background="#787878" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewSubCategories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginVertical="12dp"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="6"
                tools:itemCount="8"
                tools:listitem="@layout/item_sub_category" />

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>