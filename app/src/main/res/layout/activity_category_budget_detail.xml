<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F4F8"
    tools:context=".ui.activity.CategoryBudgetDetailActivity">

    <!-- 顶部栏（与 BudgetActivity 保持一致） -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#F2F4F8"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_back3"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="返回"/>

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="预算详情"
            android:textColor="#333333"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <!-- 占位，保持标题居中 -->
        <View
            android:layout_width="24dp"
            android:layout_height="24dp"/>
    </LinearLayout>

    <!-- 可滚动内容区域 -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/top_bar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="32dp">

            <!-- ① 分类信息 + 总预算卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <!-- 分类图标 + 名称 + 周期标签 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">

                        <ImageView
                            android:id="@+id/iv_category_icon"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:padding="8dp"
                            android:src="@drawable/ic_category_default"
                            android:scaleType="fitCenter"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:id="@+id/tv_category_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="分类名称"
                                android:textColor="#333333"
                                android:textSize="16sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:id="@+id/tv_period_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="月预算"
                                android:textColor="#888888"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- 预算 / 已用 / 剩余 三列统计 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="14dp">

                        <!-- 总预算 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:id="@+id/tv_budget_amt"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="¥0.00"
                                android:textColor="#333333"
                                android:textSize="18sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="总预算"
                                android:textColor="#888888"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <!-- 分隔线 -->
                        <View
                            android:layout_width="1dp"
                            android:layout_height="40dp"
                            android:background="#F0F0F0"/>

                        <!-- 已用 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:id="@+id/tv_spent_amt"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="¥0.00"
                                android:textColor="#FF5252"
                                android:textSize="18sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="已用"
                                android:textColor="#888888"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <!-- 分隔线 -->
                        <View
                            android:layout_width="1dp"
                            android:layout_height="40dp"
                            android:background="#F0F0F0"/>

                        <!-- 剩余/超支 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:id="@+id/tv_remaining_amt"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="¥0.00"
                                android:textColor="#4CAF50"
                                android:textSize="18sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:id="@+id/tv_remaining_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="剩余"
                                android:textColor="#888888"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- 进度条 -->
                    <ProgressBar
                        android:id="@+id/progress_detail"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:progressDrawable="@drawable/bg_progress_budget_blue"
                        android:max="100"
                        android:progress="0"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ② 消费趋势图卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- 标题行 + 周期 Tab -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="消费趋势"
                            android:textColor="#333333"
                            android:textSize="15sp"
                            android:textStyle="bold"/>

                        <!-- 趋势周期 Tab（周/月/年） -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="28dp"
                            android:orientation="horizontal"
                            android:background="@drawable/bg_capsule_small"
                            android:padding="3dp">

                            <TextView
                                android:id="@+id/tab_trend_week"
                                android:layout_width="40dp"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="周"
                                android:textSize="11sp"
                                android:textColor="#888888"/>

                            <TextView
                                android:id="@+id/tab_trend_month"
                                android:layout_width="40dp"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="月"
                                android:textSize="11sp"
                                android:background="@drawable/bg_tab_selected_blue"
                                android:textColor="#FFFFFF"/>

                            <TextView
                                android:id="@+id/tab_trend_year"
                                android:layout_width="40dp"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="年"
                                android:textSize="11sp"
                                android:textColor="#888888"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- 折线图 -->
                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/line_chart_trend"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"/>

                    <!-- 图例 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginTop="8dp">

                        <View
                            android:layout_width="14dp"
                            android:layout_height="3dp"
                            android:background="#5B8DEF"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="消费金额"
                            android:textSize="11sp"
                            android:textColor="#888888"
                            android:layout_marginStart="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ③ 账单列表卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- 标题行 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="消费记录"
                            android:textColor="#333333"
                            android:textSize="15sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tv_bill_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="共 0 笔消费"
                            android:textColor="#888888"
                            android:textSize="12sp"/>
                    </LinearLayout>

                    <!-- 空状态 -->
                    <TextView
                        android:id="@+id/tv_empty_bills"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="暂无消费记录"
                        android:textColor="#BBBBBB"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:paddingTop="24dp"
                        android:paddingBottom="24dp"
                        android:visibility="gone"/>

                    <!-- 账单 RecyclerView -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_bills"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        tools:listitem="@layout/item_bill_simple"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>