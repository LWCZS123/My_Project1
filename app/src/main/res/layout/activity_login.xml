<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F0F4FF"
    android:fitsSystemWindows="false"
    >

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- 顶部插图 -->
        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/lottieAnimation"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            app:lottie_autoPlay="true"
            app:lottie_loop="true"
            app:lottie_rawRes="@raw/login"
           />

        <!-- 上方两个圆角的内容卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="585dp"
            android:background="@drawable/bg_card_top_rounded"
            android:orientation="vertical"
            android:paddingLeft="24dp"
            android:paddingTop="28dp"
            android:paddingRight="24dp"
            android:paddingBottom="24dp">

            <!-- 登录标题 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Login"
                android:textColor="#1A1A1A"
                android:textSize="28sp"
                android:textStyle="bold" />

            <!-- 邮箱输入框 -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layout_email"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:hint="Email Address"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxStrokeColor="@color/input_stroke_color"
                app:boxStrokeWidthFocused="2dp"
                app:endIconMode="clear_text"
                app:endIconTint="@color/icon_tint"
                app:errorEnabled="true"
                app:hintTextColor="@color/accent_color"
                app:startIconDrawable="@drawable/ic_email"
                app:startIconTint="@color/icon_tint">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress"
                    android:paddingStart="40dp"
                    android:textColor="#1A1A1A"
                    android:textColorHint="#999999"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- 密码输入框 -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layout_password"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:hint="Password"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxStrokeColor="@color/input_stroke_color"
                app:boxStrokeWidthFocused="2dp"
                app:endIconMode="password_toggle"
                app:endIconTint="@color/icon_tint"
                app:errorEnabled="true"
                app:hintTextColor="@color/accent_color"
                app:startIconDrawable="@drawable/ic_lock"
                app:startIconTint="@color/icon_tint">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:paddingStart="40dp"
                    android:textColor="#1A1A1A"
                    android:textColorHint="#999999"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- 忘记密码 -->
            <TextView
                android:id="@+id/tv_forgot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="2dp"
                android:clickable="true"
                android:focusable="true"
                android:text="Forgot password?"
                android:textColor="#0066FF"
                android:textSize="13sp" />

            <!-- 登录按钮 -->
            <Button
                android:id="@+id/btn_login"
                style="@style/MyButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="10dp"
                android:stateListAnimator="@null"
                android:text="LOGIN"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- 加载条 -->
            <ProgressBar
                android:id="@+id/progress_bar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone" />

            <!-- 分割线 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#e0e0e0" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="12dp"
                    android:layout_marginRight="12dp"
                    android:text="Or login with"
                    android:textColor="#999999"
                    android:textSize="13sp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#e0e0e0" />
            </LinearLayout>

            <!-- 第三方登录 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="14dp"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btn_google"
                    android:layout_width="35dp"
                    android:layout_height="35dp"
                    android:layout_marginRight="35dp"
                    android:padding="4dp"
                    android:background="@drawable/social_button_background"
                    android:contentDescription="Google login"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_google" />

                <ImageButton
                    android:id="@+id/btn_wechat"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_marginRight="35dp"
                    android:padding="4dp"
                    android:background="@drawable/social_button_background"
                    android:contentDescription="WeChat login"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic" />

                <ImageButton
                    android:id="@+id/btn_apple"
                    android:layout_width="35dp"
                    android:layout_height="35dp"
                    android:padding="4dp"
                    android:background="@drawable/social_button_background"
                    android:contentDescription="Apple login"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_apple" />
            </LinearLayout>

            <!-- 注册提示 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Don't have an account?      "
                    android:textColor="#999999"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_register"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="Register"
                    android:textColor="#0066FF"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</ScrollView>