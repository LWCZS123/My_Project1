<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_icon_detail.xml（改造版）
    ────────────────────────────────────────────────────
    ✔ 进度条改为居中转圈 ProgressBar
    ✔ 使用 FrameLayout 覆盖 ViewPager
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/transparent">

    <!-- 图标总数 -->
    <TextView
        android:id="@+id/tv_icon_count"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingTop="4dp"
        android:paddingBottom="8dp"
        android:textColor="#AAAAAA"
        android:textSize="12sp" />

    <!-- ★ 多选模式 Toolbar（默认隐藏） -->
    <LinearLayout
        android:id="@+id/toolbar_multi_select"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:gravity="center_vertical"
        android:background="#F8F8F8"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_select_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="选择图标"
            android:textSize="14sp"
            android:textColor="#333333"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_select_all"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="全选"
            android:textSize="13sp"
            android:textColor="#0D6EFC"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/btn_confirm_select"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="确认"
            android:textSize="13sp"
            android:textColor="#304FFE"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_marginStart="8dp"
            android:alpha="0.4" />

        <TextView
            android:id="@+id/btn_cancel_select"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="取消"
            android:textSize="13sp"
            android:textColor="#666666"
            android:paddingStart="10dp"
            android:paddingEnd="4dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:layout_marginStart="4dp" />
    </LinearLayout>

    <!-- ★ 内容区域：ViewPager + 居中转圈进度条 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- ViewPager2 - 左右滑动分页 -->

        <!-- ★ 居中转圈 ProgressBar -->

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/view_pager"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <ProgressBar
            android:id="@+id/progress_detail"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:indeterminate="true"
            android:visibility="gone" />

    </FrameLayout>

    <!-- 页码指示器（多选模式下隐藏） -->
    <TextView
        android:id="@+id/tv_page_indicator"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:gravity="center"
        android:text="1 / 1"
        android:textColor="#AAAAAA"
        android:textSize="12sp" />

</LinearLayout>