<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_add_saving_record.xml
    添加存钱记录底部弹窗布局
    风格与 fragment_add_wish.xml 完全一致
    包含：金额、时间、所属账户、备注、图标（使用愿望图标）
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 标题栏 -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:text="添加存钱记录"
                    android:textColor="#333333"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_cancel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_status_tag"
                    android:padding="8dp"
                    android:text="取消"
                    android:textColor="#000000"
                    android:textSize="16sp" />
            </RelativeLayout>

            <!-- 愿望图标展示（只读，使用愿望绑定的图标） -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:gravity="center"
                android:orientation="vertical">

                <androidx.cardview.widget.CardView
                    android:layout_width="84dp"
                    android:layout_height="84dp"
                    app:cardBackgroundColor="@android:color/white"
                    app:cardCornerRadius="42dp"
                    app:cardElevation="2dp">

                    <ImageView
                        android:id="@+id/iv_wish_icon"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="20dp"
                        android:src="@drawable/ic_face"
                        android:scaleType="centerCrop" />
                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/tv_wish_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="愿望名称"
                    android:textColor="#999999"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- 主要输入表单 Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- 金额 -->
                    <LinearLayout style="@style/WishItemStyle">
                        <ImageView style="@style/WishIconStyle" android:src="@drawable/ic_money2" />
                        <EditText
                            android:id="@+id/et_amount"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@android:color/transparent"
                            android:hint="存入金额（元）"
                            android:inputType="numberDecimal"
                            android:textColor="#333333"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View style="@style/WishDividerStyle" />

                    <!-- 时间选择 -->
                    <LinearLayout
                        android:id="@+id/layout_date"
                        style="@style/WishItemStyle"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView style="@style/WishIconStyle" android:src="@drawable/ic_calendar" />
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="存入日期"
                            android:textSize="16sp" />
                        <TextView
                            android:id="@+id/tv_date"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#333333"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginStart="8dp"
                            android:src="@drawable/ic_arrow_right"
                            app:tint="#CCCCCC" />
                    </LinearLayout>

                    <View style="@style/WishDividerStyle" />

                    <!-- 所属账户 -->
                    <LinearLayout
                        android:id="@+id/layout_account"
                        style="@style/WishItemStyle"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:id="@+id/iv_account_icon"
                            style="@style/WishIconStyle"
                            android:src="@drawable/ic_wallet_change" />
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="所属账户"
                            android:textSize="16sp" />
                        <TextView
                            android:id="@+id/tv_account_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="未选择"
                            android:textColor="#999999"
                            android:textSize="15sp" />
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginStart="8dp"
                            android:src="@drawable/ic_arrow_right"
                            app:tint="#CCCCCC" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp"
                android:text="备注说明"
                android:textColor="#888888"
                android:textSize="14sp" />

            <!-- 备注 Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">
                    <ImageView style="@style/WishIconStyle" android:src="@drawable/ic_note" />
                    <EditText
                        android:id="@+id/et_note"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@android:color/transparent"
                        android:gravity="top"
                        android:hint="写下这笔存钱的备注..."
                        android:minLines="4"
                        android:textSize="16sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <View android:layout_width="match_parent" android:layout_height="120dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <Button
        android:id="@+id/btn_save"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_gravity="bottom"
        android:layout_margin="24dp"
        android:backgroundTint="#2196F3"
        android:text="确认存入"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="27dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>