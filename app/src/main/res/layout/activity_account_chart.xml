<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:scrollbars="none"
    android:fadeScrollbars="false"
    android:background="@drawable/bg_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 标题栏 -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_centerVertical="true"
                android:contentDescription="返回"
                android:src="@drawable/ic_back3" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="资产分析"
                android:textColor="#2196F3"
                android:textSize="20sp"
                android:textStyle="bold" />

        </RelativeLayout>

        <!-- 资产走势卡片 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            android:background="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- 上半部分：净资产显示和年月日切换 -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">

                    <!-- 左侧：净资产 + 账户选择 -->
                    <LinearLayout
                        android:id="@+id/layoutNetAsset"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <ImageView
                            android:id="@+id/ivNetAssetIcon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_growth"
                            android:layout_marginEnd="6dp"
                            android:contentDescription="净资产图标" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="净资产"
                            android:textColor="#666666"
                            android:textSize="16sp" />

                        <ImageView
                            android:id="@+id/btnAccountPicker"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginStart="8dp"
                            android:src="@drawable/ic_down_arrow"
                            android:contentDescription="选择账户"
                            app:tint="#8F8E8E"
                            />
                    </LinearLayout>

                    <!-- 右侧：年/月/日切换 -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:orientation="horizontal"
                        android:background="@drawable/bg_tab_group"
                        android:padding="4dp">

                        <TextView
                            android:id="@+id/btnYear"
                            android:layout_width="50dp"
                            android:layout_height="32dp"
                            android:text="年"
                            android:gravity="center"
                            android:textColor="#666666"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/btnMonth"
                            android:layout_width="50dp"
                            android:layout_height="32dp"
                            android:text="月"
                            android:gravity="center"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:background="@drawable/bg_tab_selected" />

                        <TextView
                            android:id="@+id/btnDay"
                            android:layout_width="50dp"
                            android:layout_height="32dp"
                            android:text="日"
                            android:gravity="center"
                            android:textColor="#666666"
                            android:textSize="14sp" />
                    </LinearLayout>
                </RelativeLayout>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="200dp">

                    <!-- 折线图 -->
                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/lineChart"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"/>

                    <!-- 无数据占位 -->
                    <LinearLayout
                        android:id="@+id/layoutLineNoData"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:visibility="gone">

                        <ImageView
                            android:layout_width="180dp"
                            android:layout_height="180dp"
                            android:src="@drawable/ic_no_data"
                            android:alpha="0.85"
                            android:contentDescription="暂无数据图标" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="暂无数据"
                            android:textColor="#999999"
                            android:textSize="16sp"
                            android:layout_marginTop="12dp" />
                    </LinearLayout>
                </FrameLayout>

                <!-- 合并显示 -->
                <LinearLayout
                    android:id="@+id/layoutMergeDisplay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_marginTop="4dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground"
                    android:padding="4dp">

                    <ImageView
                        android:id="@+id/ivMergeDisplay"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_merge"
                        android:contentDescription="合并显示开关" />

                    <TextView
                        android:id="@+id/tvMergeDisplay"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="合并显示"
                        android:textColor="#666666"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 资产占比卡片 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            android:background="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- 标题栏：资产占比 + 资产/负资产切换 -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp">

                    <!-- 左侧：资产占比 -->
                    <LinearLayout
                        android:id="@+id/layoutPieTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true">

                        <ImageView
                            android:id="@+id/ivPieTitleIcon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_pie_chart"
                            android:layout_marginEnd="6dp"
                            android:contentDescription="资产占比图标" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="资产占比"
                            android:textColor="#333333"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                    <!-- 右侧：资产/负资产切换 -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:orientation="horizontal"
                        android:background="@drawable/bg_tab_group"
                        android:padding="4dp">

                        <TextView
                            android:id="@+id/btnAsset"
                            android:layout_width="70dp"
                            android:layout_height="32dp"
                            android:text="资产"
                            android:gravity="center"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:background="@drawable/bg_tab_selected" />

                        <TextView
                            android:id="@+id/btnLiability"
                            android:layout_width="70dp"
                            android:layout_height="32dp"
                            android:text="负资产"
                            android:gravity="center"
                            android:textColor="#666666"
                            android:textSize="14sp" />
                    </LinearLayout>
                </RelativeLayout>

                <!-- 饼状图 -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="200dp">

                    <com.github.mikephil.charting.charts.PieChart
                        android:id="@+id/pieChart"
                        android:layout_gravity="center"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                    <!-- 无数据时显示 -->
                    <LinearLayout
                        android:id="@+id/layoutPieNoData"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:visibility="gone">

                        <ImageView
                            android:layout_width="180dp"
                            android:layout_height="180dp"
                            android:src="@drawable/ic_no_data"
                            android:contentDescription="暂无数据图标"
                            android:alpha="0.8"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="暂无数据"
                            android:textColor="#999999"
                            android:textSize="16sp"
                            android:layout_marginTop="12dp"/>
                    </LinearLayout>
                </FrameLayout>


            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>