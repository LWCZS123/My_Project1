<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- ① 拖拽把手 -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/bg_drag_handle" />

        <!-- ② 标题 -->
        <TextView
            android:id="@+id/tv_save_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="8dp"
            android:paddingBottom="4dp"
            android:text="保存图标为分类"
            android:textSize="17sp"
            android:textColor="#111111"
            android:textStyle="bold" />

        <!-- ③ 收入 / 支出 胶囊 -->
        <LinearLayout
            android:id="@+id/ll_type_tabs"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_capsule1"
            android:padding="4dp">

            <TextView
                android:id="@+id/tab_expense"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_tab_selected1"
                android:gravity="center"
                android:text="支出分类"
                android:textSize="13sp"
                android:textColor="#333333" />

            <TextView
                android:id="@+id/tab_income"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="收入分类"
                android:textSize="13sp"
                android:textColor="#333333" />

        </LinearLayout>

        <!-- ④ 一级 / 二级 分类胶囊 -->
        <LinearLayout
            android:id="@+id/ll_level_tabs"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_capsule1"
            android:padding="4dp">

            <TextView
                android:id="@+id/btn_tab_first"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_tab_selected1"
                android:gravity="center"
                android:text="一级分类"
                android:textSize="13sp"
                android:textColor="#333333" />

            <TextView
                android:id="@+id/btn_tab_second"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="二级分类"
                android:textSize="13sp"
                android:textColor="#333333" />

        </LinearLayout>

        <!-- ⑤ 已选图标预览 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#F6F7FB">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/tv_selected_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="已选图标"
                    android:textSize="12sp"
                    android:textColor="#888888"
                    android:layout_marginBottom="8dp" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:scrollbars="none"
                    android:overScrollMode="never">

                    <LinearLayout
                        android:id="@+id/ll_selected_icons"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp" />

                </HorizontalScrollView>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 保存进度条 -->
        <ProgressBar
            android:id="@+id/progress_saving"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:layout_marginTop="8dp"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:indeterminate="true"
            android:visibility="gone" />

        <!-- ⑥ 内容卡片 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#F6F7FB">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- 一级分类 -->
                <LinearLayout
                    android:id="@+id/panel_first"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="每个图标名称将作为分类名称，独立创建为一级分类"
                        android:textSize="13sp"
                        android:textColor="#666666" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="同名分类已存在时将自动跳过，不产生重复数据"
                        android:textSize="13sp"
                        android:textColor="#666666" />

                </LinearLayout>

                <!-- 二级分类 -->
                <LinearLayout
                    android:id="@+id/panel_second"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tv_second_hint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:text="请先创建一级分类，才能添加二级分类"
                        android:textSize="13sp"
                        android:textColor="#FF6B6B"
                        android:visibility="gone" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="10dp"
                        android:text="选择目标一级分类"
                        android:textSize="13sp"
                        android:textColor="#888888" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_parent_categories"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:layout_marginStart="12dp"
                        android:layout_marginEnd="12dp"
                        android:layout_marginBottom="12dp"
                        android:nestedScrollingEnabled="true"
                        android:overScrollMode="never"
                        android:clipToPadding="false" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ⑦ 确认按钮 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_confirm_save"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="确认添加"
            android:textSize="15sp"
            android:textColor="@android:color/white"
            app:cornerRadius="22dp"
            app:backgroundTint="#304FFE"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="4dp" />

    </LinearLayout>

</ScrollView>