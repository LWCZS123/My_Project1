<?xml version="1.0" encoding="utf-8"?>
<!--
    分类预算条目布局
    参考设计：左侧圆形图标 + 中部名称/进度条/金额 + 右侧操作按钮
    风格与提供的参考图片保持一致（白色卡片、橙色进度点、蓝灰进度条）
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- 左侧：分类图标（圆形背景） -->
        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_circle_icon">

            <ImageView
                android:id="@+id/iv_category_icon"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_category_default"
                android:scaleType="centerInside"
                android:contentDescription="分类图标"/>
        </FrameLayout>

        <!-- 中部：名称 + 进度条 + 金额 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp">

            <!-- 顶部行：分类名称 + 预算金额 + 周期 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_category_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="购物"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#333333"/>

                <TextView
                    android:id="@+id/tv_budget_amount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="预算 ¥100.00"
                    android:textSize="12sp"
                    android:textColor="#888888"/>

                <TextView
                    android:id="@+id/tv_period"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="/月"
                    android:textSize="11sp"
                    android:textColor="#AAAAAA"
                    android:layout_marginStart="2dp"/>
            </LinearLayout>

            <!-- 进度条（圆角，蓝灰背景 + 彩色前景） -->
            <ProgressBar
                android:id="@+id/progress_bar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="6dp"
                android:progress="0"
                android:max="100"
                android:progressDrawable="@drawable/bg_progress_budget_item"
                android:background="@drawable/bg_progress_budget_track"/>

            <!-- 底部行：已用 + 可用/超支 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_spent"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="已用 ¥0.00"
                    android:textSize="12sp"
                    android:textColor="#999999"/>

                <TextView
                    android:id="@+id/tv_available"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="可用 ¥100.00"
                    android:textSize="12sp"
                    android:textColor="#4CAF50"/>
            </LinearLayout>
        </LinearLayout>

        <!-- 右侧：编辑 / 删除操作按钮列 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:id="@+id/btn_edit"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_pencil"
                android:contentDescription="编辑"
                android:clickable="true"
                android:focusable="true"
                android:padding="2dp"/>

            <View
                android:layout_width="1dp"
                android:layout_height="8dp"/>

            <ImageView
                android:id="@+id/btn_delete"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_delete"
                android:contentDescription="删除"
                android:clickable="true"
                android:focusable="true"
                android:padding="2dp"/>
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>