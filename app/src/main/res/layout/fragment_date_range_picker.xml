<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet1"
    android:paddingTop="16dp"
    android:paddingBottom="24dp">

    <!-- 标题 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="选择日期范围"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#2D3436"
        android:layout_marginBottom="20dp" />

    <!-- 日期范围选择区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        android:layout_marginBottom="24dp">

        <!-- 开始日期 -->
        <LinearLayout
            android:id="@+id/layout_start_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_date_selector"
            android:paddingVertical="12dp"
            android:paddingHorizontal="16dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="开始日期"
                android:textSize="12sp"
                android:textColor="#636E72"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tv_start_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2026.01.01"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#2D3436" />


        </LinearLayout>

        <!-- 分隔线 -->
        <View
            android:layout_width="24dp"
            android:layout_height="2dp"
            android:background="#B2BEC3"
            android:layout_marginHorizontal="12dp" />

        <!-- 结束日期 -->
        <LinearLayout
            android:id="@+id/layout_end_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_date_selector"
            android:paddingVertical="12dp"
            android:paddingHorizontal="16dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="结束日期"
                android:textSize="12sp"
                android:textColor="#636E72"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tv_end_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2026.01.31"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#2D3436" />

        </LinearLayout>
    </LinearLayout>

    <!-- 按钮区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:gravity="center">

        <!-- 取消按钮 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="取消"
            android:textSize="15sp"
            android:textColor="#636E72"
            app:backgroundTint="#F5F5F5"
            app:cornerRadius="12dp"
            app:elevation="0dp"
            android:layout_marginEnd="8dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <!-- 确认按钮 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_confirm"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="确认"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            app:backgroundTint="#007AFF"
            app:cornerRadius="12dp"
            app:elevation="0dp"
            android:layout_marginStart="8dp"
            style="@style/Widget.MaterialComponents.Button" />
    </LinearLayout>

</LinearLayout>