<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@+id/root"

    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F4F8"
    tools:context=".ui.activity.BudgetActivity">

    <!-- 顶部栏 -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#F2F4F8"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_back3"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="返回"/>

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="预算管理"
            android:textColor="#333333"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <ImageView
            android:id="@+id/iv_add_budget"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_multiple"
            android:contentDescription="新增预算"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- 可滚动内容区域 -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/top_bar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="32dp">

            <!-- ① 总预算卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <!-- 上方：左信息 + 右装饰图 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- 左信息列 -->
                        <LinearLayout
                            android:id="@+id/ll_info"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <!-- 标题 + 日期 -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <TextView
                                    android:id="@+id/tv_month"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="本月"
                                    android:textColor="#333333"
                                    android:textSize="16sp"/>

                                <TextView
                                    android:id="@+id/tv_date_range"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="（3.1-3.31）"
                                    android:textSize="13sp"
                                    android:textColor="#888888"
                                    android:layout_marginStart="4dp"/>
                            </LinearLayout>

                            <!-- 胶囊 Tab + 预算标签 -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginTop="6dp"
                                android:layout_marginBottom="4dp">

                                <LinearLayout
                                    android:id="@+id/ll_pie_type_tabs"
                                    android:layout_width="wrap_content"
                                    android:layout_height="24dp"
                                    android:orientation="horizontal"
                                    android:background="@drawable/bg_capsule_small"
                                    android:padding="3dp">

                                    <TextView
                                        android:id="@+id/tab_pie_expense"
                                        android:layout_width="36dp"
                                        android:layout_height="match_parent"
                                        android:gravity="center"
                                        android:text="月预算"
                                        android:textSize="8sp"
                                        android:background="@drawable/bg_tab_selected_blue"
                                        android:textColor="#FFFFFF"/>

                                    <TextView
                                        android:id="@+id/tab_pie_income"
                                        android:layout_width="36dp"
                                        android:layout_height="match_parent"
                                        android:gravity="center"
                                        android:text="年预算"
                                        android:textSize="8sp"
                                        android:textColor="#888"/>
                                </LinearLayout>

                                <TextView
                                    android:id="@+id/tv_month_budget"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:text="月预算"
                                    android:textColor="#888888"
                                    android:textSize="13sp"/>
                            </LinearLayout>

                            <!-- 金额大字 -->
                            <TextView
                                android:id="@+id/tv_budget_amount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="¥0"
                                android:textColor="#333333"
                                android:textSize="28sp"
                                android:textStyle="bold"/>

                        </LinearLayout>

                        <!-- 右：编辑按钮 -->
                        <ImageView
                            android:id="@+id/iv_edit_budget"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_pencil"
                            android:contentDescription="编辑预算"
                            android:layout_gravity="top"
                            android:clickable="true"
                            android:focusable="true"/>
                    </LinearLayout>

                    <!-- 进度条区域 -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:clipChildren="false">

                        <ProgressBar
                            android:id="@+id/progress_budget"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="10dp"
                            android:max="100"
                            android:progress="0"
                            android:layout_gravity="center_vertical"
                            android:progressDrawable="@drawable/bg_progress_budget_item"/>

                        <ImageView
                            android:id="@+id/iv_progress_indicator"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center_vertical"
                            android:scaleType="centerInside"
                            android:src="@drawable/ic_progress_image"
                            android:elevation="2dp"/>

                    </FrameLayout>

                    <!-- 底部已用 / 剩余 文字 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="6dp">

                        <TextView
                            android:id="@+id/tv_used"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="已用：¥0"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#666666"/>

                        <TextView
                            android:id="@+id/tv_over"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="剩余：¥0"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#4CAF50"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ② 图表卡片（折线图 + 饼图，可切换） -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- 标题行 + 图表类型切换 Tab -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="预算分析"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#333333"/>

                        <!-- 图表类型切换：折线 / 饼图 -->
                        <LinearLayout
                            android:id="@+id/ll_chart_type_tabs"
                            android:layout_width="wrap_content"
                            android:layout_height="28dp"
                            android:orientation="horizontal"
                            android:background="@drawable/bg_capsule_small"
                            android:padding="3dp">

                            <TextView
                                android:id="@+id/tab_chart_line"
                                android:layout_width="48dp"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="趋势"
                                android:textSize="11sp"
                                android:background="@drawable/bg_tab_selected_blue"
                                android:textColor="#FFFFFF"/>

                            <TextView
                                android:id="@+id/tab_chart_pie"
                                android:layout_width="48dp"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="分配"
                                android:textSize="11sp"
                                android:textColor="#888"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- 折线图容器（默认显示） -->
                    <LinearLayout
                        android:id="@+id/ll_line_chart_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="visible">

                        <com.github.mikephil.charting.charts.LineChart
                            android:id="@+id/line_chart"
                            android:layout_width="match_parent"
                            android:layout_height="200dp"/>

                        <!-- 图例 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:layout_marginTop="6dp">

                            <View
                                android:layout_width="12dp"
                                android:layout_height="3dp"
                                android:background="#5B8DEF"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="累计支出"
                                android:textSize="11sp"
                                android:textColor="#888888"
                                android:layout_marginStart="4dp"/>

                            <View
                                android:layout_width="12dp"
                                android:layout_height="3dp"
                                android:background="#FF5252"
                                android:layout_marginStart="16dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="超支段"
                                android:textSize="11sp"
                                android:textColor="#888888"
                                android:layout_marginStart="4dp"/>

                            <View
                                android:layout_width="12dp"
                                android:layout_height="3dp"
                                android:background="#4CAF50"
                                android:layout_marginStart="16dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="预算线"
                                android:textSize="11sp"
                                android:textColor="#888888"
                                android:layout_marginStart="4dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- 饼图容器（默认隐藏） -->
                    <LinearLayout
                        android:id="@+id/ll_pie_chart_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <!--
                            ✅ 高度从 240dp 改为 300dp，底部为图例留出空间，
                            防止图例文字被截断。
                        -->
                        <com.github.mikephil.charting.charts.PieChart
                            android:id="@+id/pie_chart"
                            android:layout_width="match_parent"
                            android:layout_height="300dp"/>

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ③ 分类预算标题行 + 剩余可分配提示 + 添加按钮 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp">

                <!-- 标题行 + 添加按钮 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="分类预算"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#333333"/>

                    <LinearLayout
                        android:id="@+id/btn_add_category_budget"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_btn_add_category"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_multiple"
                            android:contentDescription="添加"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="添加分类预算"
                            android:textSize="13sp"
                            android:textColor="#5B8DEF"
                            android:layout_marginStart="4dp"/>
                    </LinearLayout>
                </LinearLayout>


                <TextView
                    android:id="@+id/tv_remaining_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textSize="12sp"
                    android:textColor="#5B8DEF"
                    android:text="剩余可分配：¥—"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- ④ 分类预算 RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_category_budgets"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_category_budget"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>