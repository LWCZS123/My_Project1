<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingBottom="32dp">

    <!-- 顶部标题栏 -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="账户信息"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#2D3436"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="12dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/iv_close"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="HardcodedText" />

    <ImageView
        android:id="@+id/iv_close"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_close"
        android:padding="6dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="ContentDescription" />

    <!-- 主内容卡片 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_content"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="56dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_title">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="20dp">

            <!-- 账户名称和类型 -->
            <TextView
                android:id="@+id/tv_account_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="花呗"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#2D3436"
                android:layout_marginTop="48dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:ignore="HardcodedText" />

            <TextView
                android:id="@+id/tv_account_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="信用账户"
                android:textSize="13sp"
                android:textColor="#636E72"
                android:layout_marginTop="4dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_account_name"
                tools:ignore="HardcodedText" />

            <!-- 分隔线 -->
            <View
                android:id="@+id/divider_1"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:background="#F0F0F0"
                android:layout_marginTop="20dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_account_type" />

            <!-- 余额区域 -->
            <ImageView
                android:id="@+id/iv_balance_icon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_money1"
                app:tint="#636E72"
                android:layout_marginStart="20dp"
                android:layout_marginTop="16dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/divider_1"
                tools:ignore="ContentDescription" />

            <TextView
                android:id="@+id/tv_balance_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="余额"
                android:textSize="15sp"
                android:textColor="#2D3436"
                android:layout_marginStart="10dp"
                app:layout_constraintStart_toEndOf="@id/iv_balance_icon"
                app:layout_constraintTop_toTopOf="@id/iv_balance_icon"
                app:layout_constraintBottom_toBottomOf="@id/iv_balance_icon"
                tools:ignore="HardcodedText" />

            <TextView
                android:id="@+id/tv_balance_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-¥53.00"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#2D3436"
                android:layout_marginEnd="20dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/tv_balance_label"
                app:layout_constraintBottom_toBottomOf="@id/tv_balance_label"
                tools:ignore="HardcodedText" />

            <!-- 分隔线 -->
            <View
                android:id="@+id/divider_2"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:background="#F0F0F0"
                android:layout_marginTop="16dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_balance_label" />

            <!-- 信用额度区域（仅信用账户显示） -->
            <ImageView
                android:id="@+id/iv_credit_limit_icon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_liability1"
                app:tint="#636E72"
                android:layout_marginStart="20dp"
                android:layout_marginTop="16dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/divider_2"
                tools:ignore="ContentDescription" />

            <TextView
                android:id="@+id/tv_credit_limit_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="信用额度"
                android:textSize="15sp"
                android:textColor="#2D3436"
                android:layout_marginStart="10dp"
                app:layout_constraintStart_toEndOf="@id/iv_credit_limit_icon"
                app:layout_constraintTop_toTopOf="@id/iv_credit_limit_icon"
                app:layout_constraintBottom_toBottomOf="@id/iv_credit_limit_icon"
                tools:ignore="HardcodedText" />

            <TextView
                android:id="@+id/tv_credit_limit_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¥5000.00"
                android:textSize="16sp"
                android:textColor="#2D3436"
                android:layout_marginEnd="20dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/tv_credit_limit_label"
                app:layout_constraintBottom_toBottomOf="@id/tv_credit_limit_label"
                tools:ignore="HardcodedText" />

            <!-- 分隔线 -->
            <View
                android:id="@+id/divider_3"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:background="#F0F0F0"
                android:layout_marginTop="16dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_credit_limit_label" />

            <!-- 账户组区域 -->
            <ImageView
                android:id="@+id/iv_group_icon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_category"
                app:tint="#636E72"
                android:layout_marginStart="20dp"
                android:layout_marginTop="16dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/divider_3"
                tools:ignore="ContentDescription" />

            <TextView
                android:id="@+id/tv_group_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="账户组"
                android:textSize="15sp"
                android:textColor="#2D3436"
                android:layout_marginStart="10dp"
                app:layout_constraintStart_toEndOf="@id/iv_group_icon"
                app:layout_constraintTop_toTopOf="@id/iv_group_icon"
                app:layout_constraintBottom_toBottomOf="@id/iv_group_icon"
                tools:ignore="HardcodedText" />

            <TextView
                android:id="@+id/tv_group_value"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="现金账户"
                android:textSize="14sp"
                android:textColor="#636E72"
                android:gravity="end"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="20dp"
                app:layout_constraintStart_toEndOf="@id/tv_group_label"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/tv_group_label"
                app:layout_constraintBottom_toBottomOf="@id/tv_group_label"
                tools:ignore="HardcodedText" />

            <!-- 分隔线 -->
            <View
                android:id="@+id/divider_4"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:background="#F0F0F0"
                android:layout_marginTop="16dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_group_label" />

            <!-- 创建日期区域 -->
            <ImageView
                android:id="@+id/iv_date_icon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_calendar3"
                app:tint="#636E72"
                android:layout_marginStart="20dp"
                android:layout_marginTop="16dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/divider_4"
                tools:ignore="ContentDescription" />

            <TextView
                android:id="@+id/tv_date_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="创建日期"
                android:textSize="15sp"
                android:textColor="#2D3436"
                android:layout_marginStart="10dp"
                app:layout_constraintStart_toEndOf="@id/iv_date_icon"
                app:layout_constraintTop_toTopOf="@id/iv_date_icon"
                app:layout_constraintBottom_toBottomOf="@id/iv_date_icon"
                tools:ignore="HardcodedText" />

            <TextView
                android:id="@+id/tv_date_value"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="2024-01-18"
                android:textSize="14sp"
                android:textColor="#636E72"
                android:gravity="end"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="20dp"
                app:layout_constraintStart_toEndOf="@id/tv_date_label"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/tv_date_label"
                app:layout_constraintBottom_toBottomOf="@id/tv_date_label"
                tools:ignore="HardcodedText" />

            <!-- 分隔线 -->
            <View
                android:id="@+id/divider_5"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:background="#F0F0F0"
                android:layout_marginTop="16dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_date_label" />

            <!-- 卡号区域 -->
            <ImageView
                android:id="@+id/iv_card_icon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_card"
                app:tint="#636E72"
                android:layout_marginStart="20dp"
                android:layout_marginTop="16dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/divider_5"
                tools:ignore="ContentDescription" />

            <TextView
                android:id="@+id/tv_card_number_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="卡号"
                android:textSize="15sp"
                android:textColor="#2D3436"
                android:layout_marginStart="10dp"
                app:layout_constraintStart_toEndOf="@id/iv_card_icon"
                app:layout_constraintTop_toTopOf="@id/iv_card_icon"
                app:layout_constraintBottom_toBottomOf="@id/iv_card_icon"
                tools:ignore="HardcodedText" />

            <TextView
                android:id="@+id/tv_card_number_value"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="未设置"
                android:textSize="14sp"
                android:textColor="#636E72"
                android:gravity="end"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="20dp"
                app:layout_constraintStart_toEndOf="@id/tv_card_number_label"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/tv_card_number_label"
                app:layout_constraintBottom_toBottomOf="@id/tv_card_number_label"
                tools:ignore="HardcodedText" />

            <!-- 分隔线 -->
            <View
                android:id="@+id/divider_6"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:background="#F0F0F0"
                android:layout_marginTop="16dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_card_number_label" />

            <!-- 备注区域（优化为多行显示） -->
            <ImageView
                android:id="@+id/iv_remark_icon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_note"
                app:tint="#636E72"
                android:layout_marginStart="20dp"
                android:layout_marginTop="16dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/divider_6"
                tools:ignore="ContentDescription" />

            <TextView
                android:id="@+id/tv_remark_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="备注"
                android:textSize="15sp"
                android:textColor="#2D3436"
                android:layout_marginStart="10dp"
                app:layout_constraintStart_toEndOf="@id/iv_remark_icon"
                app:layout_constraintTop_toTopOf="@id/iv_remark_icon"
                tools:ignore="HardcodedText" />

            <!-- 备注内容（独占一行，支持多行显示） -->
            <TextView
                android:id="@+id/tv_remark_value"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:background="@drawable/bg_input_gray"
                android:textColor="#636E72"
                android:lineSpacingExtra="4dp"
                android:layout_marginStart="50dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="8dp"
                android:minHeight="48dp"
                android:padding="6dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_remark_label"
                tools:ignore="HardcodedText" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 账户图标（一半在卡片外） -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_icon_container"
        android:layout_width="72dp"
        android:layout_height="72dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="#795078E6"
        app:cardBackgroundColor="#EEF8FF"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/card_content"
        app:layout_constraintBottom_toTopOf="@id/card_content">

        <ImageView
            android:id="@+id/iv_account_icon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_wallet"
            tools:ignore="ContentDescription" />
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>