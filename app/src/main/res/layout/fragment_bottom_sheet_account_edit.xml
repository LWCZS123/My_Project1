<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet1"
    android:paddingBottom="24dp">

    <!-- 顶部标题栏 -->
    <TextView
        android:id="@+id/tv_title_main"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="账户信息"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#2D3436"
        android:layout_marginTop="20dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/iv_close"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_close"
        android:padding="8dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_title_main"
        app:layout_constraintBottom_toBottomOf="@id/tv_title_main" />

    <!-- 主内容卡片 (居中) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="60dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/tv_title_main">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="20dp">

            <!-- 账户名称和类型 -->
            <TextView
                android:id="@+id/tv_account_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="账户名称"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#2D3436"
                android:layout_marginTop="48dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tv_account_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="储蓄账户"
                android:textSize="13sp"
                android:textColor="#636E72"
                android:layout_marginTop="4dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_account_name" />

            <!-- 分隔线 -->
            <View
                android:id="@+id/divider_1"
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="#F0F0F0"
                android:layout_marginTop="20dp"
                app:layout_constraintTop_toBottomOf="@id/tv_account_type" />

            <!-- 余额区域 -->
            <LinearLayout
                android:id="@+id/layout_balance"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                app:layout_constraintTop_toBottomOf="@id/divider_1">

                <ImageView
                    android:id="@+id/iv_balance_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_money1"
                    app:tint="#636E72" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="余额"
                    android:textSize="15sp"
                    android:textColor="#2D3436"
                    android:layout_marginStart="10dp" />

                <TextView
                    android:id="@+id/tv_balance_value"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="¥0.00"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="#2D3436"
                    android:gravity="end" />
            </LinearLayout>

            <View
                android:id="@+id/divider_2"
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="#F0F0F0"
                app:layout_constraintTop_toBottomOf="@id/layout_balance" />

            <!-- 账户组 -->
            <LinearLayout
                android:id="@+id/layout_group"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                app:layout_constraintTop_toBottomOf="@id/divider_2">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_category"
                    app:tint="#636E72" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="账户组"
                    android:textSize="15sp"
                    android:textColor="#2D3436"
                    android:layout_marginStart="10dp" />

                <TextView
                    android:id="@+id/tv_group_value"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="未分组"
                    android:textSize="14sp"
                    android:textColor="#636E72"
                    android:gravity="end" />
            </LinearLayout>

            <View
                android:id="@+id/divider_3"
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="#F0F0F0"
                app:layout_constraintTop_toBottomOf="@id/layout_group" />

            <!-- 创建日期 -->
            <LinearLayout
                android:id="@+id/layout_date"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                app:layout_constraintTop_toBottomOf="@id/divider_3">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_calendar3"
                    app:tint="#636E72" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="创建日期"
                    android:textSize="15sp"
                    android:textColor="#2D3436"
                    android:layout_marginStart="10dp" />

                <TextView
                    android:id="@+id/tv_date_value"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="2024-07-18"
                    android:textSize="14sp"
                    android:textColor="#636E72"
                    android:gravity="end" />
            </LinearLayout>

            <View
                android:id="@+id/divider_4"
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="#F0F0F0"
                app:layout_constraintTop_toBottomOf="@id/layout_date" />

            <!-- 卡号 -->
            <LinearLayout
                android:id="@+id/layout_card"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                app:layout_constraintTop_toBottomOf="@id/divider_4">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_card"
                    app:tint="#636E72" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="卡号"
                    android:textSize="15sp"
                    android:textColor="#2D3436"
                    android:layout_marginStart="10dp" />

                <TextView
                    android:id="@+id/tv_card_number_value"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="未设置"
                    android:textSize="14sp"
                    android:textColor="#636E72"
                    android:gravity="end" />
            </LinearLayout>

            <View
                android:id="@+id/divider_5"
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="#F0F0F0"
                app:layout_constraintTop_toBottomOf="@id/layout_card" />

            <!-- 备注 -->
            <LinearLayout
                android:id="@+id/layout_remark"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/divider_5">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_note"
                        app:tint="#636E72" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="备注"
                        android:textSize="15sp"
                        android:textColor="#2D3436"
                        android:layout_marginStart="10dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_remark_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input_gray"
                    android:padding="12dp"
                    android:text="无"
                    android:textColor="#636E72"
                    android:textSize="14sp"
                    android:minHeight="48dp" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 账户图标 -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="72dp"
        android:layout_height="72dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="#795078E6"
        app:cardBackgroundColor="#EEF8FF"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/card_content"
        app:layout_constraintBottom_toTopOf="@id/card_content">

        <ImageView
            android:id="@+id/iv_account_icon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_wallet" />
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
