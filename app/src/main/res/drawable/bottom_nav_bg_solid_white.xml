<?xml version="1.0" encoding="utf-8"?>
<!-- iOS风格毛玻璃背景 - 基础版（适用于所有API） -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 1. 半透明白色背景层 -->
    <item>
        <shape android:shape="rectangle">
            <!-- 高透明度的白色，模拟毛玻璃效果 -->
            <solid android:color="#E6FFFFFF" />  <!-- 90%不透明 -->
            <corners android:radius="28dp" />
        </shape>
    </item>

    <!-- 2. 顶部高光层（模拟光泽） -->
    <item android:top="0dp" android:height="28dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#20FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="270"
                android:type="linear" />
            <corners
                android:topLeftRadius="28dp"
                android:topRightRadius="28dp" />
        </shape>
    </item>

    <!-- 3. 底部渐变阴影（增加深度） -->
    <item android:top="48dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#00000000"
                android:endColor="#08000000"
                android:angle="270"
                android:type="linear" />
            <corners
                android:bottomLeftRadius="28dp"
                android:bottomRightRadius="28dp" />
        </shape>
    </item>

    <!-- 4. 细边框（增强立体感） -->
    <item>
        <shape android:shape="rectangle">
            <stroke
                android:width="0.5dp"
                android:color="#33FFFFFF" />
            <corners android:radius="28dp" />
        </shape>
    </item>

    <!-- 5. 外边框 -->
    <item>
        <shape android:shape="rectangle">
            <stroke
                android:width="1dp"
                android:color="#15000000" />
            <corners android:radius="28dp" />
        </shape>
    </item>

</layer-list>