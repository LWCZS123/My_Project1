<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 外部大圆 淡色背景 -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#0091EA"/> <!--🌈 蓝白淡色，可改 -->
        </shape>
    </item>

    <!-- 内圆描边（形成中间偏白的内圈） -->
    <item android:insetLeft="4dp" android:insetTop="4dp"
        android:insetRight="4dp" android:insetBottom="4dp">
        <shape android:shape="oval">
            <solid android:color="#E3F2FD"/> <!--中心更亮，看起来像内圈-->
            <stroke android:width="1dp" android:color="#C6CDEA"/> <!--浅灰描边-->
        </shape>
    </item>

</layer-list>
