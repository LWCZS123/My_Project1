<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <!-- 背景色，建议用 @color/xxx -->
    <solid android:color="#BBDEFB"/>

    <!-- 圆角半径 -->
    <corners android:radius="12dp"/>

    <!-- 可选：内边距 -->
    <padding
        android:left="12dp"
        android:top="8dp"
        android:right="12dp"
        android:bottom="8dp"/>
</shape>
