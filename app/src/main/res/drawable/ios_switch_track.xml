<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 开启状态（绿色背景带白色圆点） -->
    <item android:state_checked="true">
        <shape android:shape="rectangle">
            <size android:width="52dp" android:height="30dp" /> <!-- 滑道尺寸 -->
            <corners android:radius="15dp" /> <!-- 圆角等于高度一半 -->
            <solid android:color="#4CD964" />

        </shape>
    </item>

    <!-- 关闭状态（灰色背景带白色圆点） -->
    <item>
        <shape android:shape="rectangle">
            <size android:width="52dp" android:height="30dp" /> <!-- 与开启状态尺寸一致 -->
            <corners android:radius="15dp" />
            <solid android:color="#E5E5EA" /> <!-- iOS灰色 -->
        </shape>
    </item>
</selector>