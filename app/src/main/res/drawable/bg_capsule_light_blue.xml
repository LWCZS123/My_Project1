<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- 胶囊圆角 -->
    <corners android:radius="50dp"/>

    <!-- 浅蓝色背景 -->
    <solid android:color="#BBDEFB"/>

    <!-- 内边距（让文字不会贴边） -->
    <padding
        android:left="10dp"
        android:right="10dp"
        android:top="2dp"
        android:bottom="2dp"/>

</shape>
