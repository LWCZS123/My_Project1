<?xml version="1.0" encoding="utf-8"?>
<!-- iOS风格FAB毛玻璃背景 -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 1. 半透明白色圆形背景 -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#E6FFFFFF" />  <!-- 90%不透明 -->
        </shape>
    </item>

    <!-- 2. 顶部高光 -->
    <item android:top="0dp" android:bottom="32dp">
        <shape android:shape="oval">
            <gradient
                android:startColor="#20FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="270"
                android:type="radial"
                android:gradientRadius="28" />
        </shape>
    </item>

    <!-- 3. 内边框高光 -->
    <item android:top="1dp" android:bottom="1dp" android:left="1dp" android:right="1dp">
        <shape android:shape="oval">
            <stroke
                android:width="0.5dp"
                android:color="#40FFFFFF" />
        </shape>
    </item>

    <!-- 4. 外边框 -->
    <item>
        <shape android:shape="oval">
            <stroke
                android:width="1dp"
                android:color="#15000000" />
        </shape>
    </item>

</layer-list>